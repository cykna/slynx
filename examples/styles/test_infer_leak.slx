stylesheet Bg(color: int) uses Fg(color | 0x00ff00) {
	let c = color * 2;
	styles {
		backgroundColor: color,
		foregroundColor: c,
	}
}
stylesheet Fg(color: int) {
	styles {
		foregroundColor: color
	}
}

component Pedrinho {
	Div {
		style: Bg(12),
		Text {
			text: "Pedrinho leitazedo"
		}
	}
}

component Jorgin {

	Text {
		style: Fg(0xff00ff),
		text: "Jorginho neguinho"
	}
	Pedrinho {}
}

func main(): Component {
	let a = 5;
	let b = 12;
	let c = a + b;
	Jorgin {}
}
