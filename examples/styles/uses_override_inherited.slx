stylesheet Base() {
    styles {
        default {
            foregroundColor: 0xff0000
        }
    }
}

stylesheet Derived() uses Base() {
    styles {
        default {
            foregroundColor: 0x00ff00
        }
    }
}

component Root {
    Div {
        style: Derived(),
        Text {
            text: "hello"
        }
    }
}

func main(): Component {
    Root {}
}
